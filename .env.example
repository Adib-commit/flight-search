# Data provider: "rapidapi" (Skyscanner data, one RapidAPI key — recommended),
# "kiwi", "amadeus", or "mock" (offline sample data, no key)
PROVIDER=rapidapi

# RapidAPI / Sky-Scrapper (https://rapidapi.com/apiheya/api/sky-scrapper)
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=sky-scrapper.p.rapidapi.com
RAPIDAPI_MARKET=US

# Kiwi.com Tequila API (https://tequila.kiwi.com) — when PROVIDER=kiwi
KIWI_API_KEY=your_kiwi_key_here

# Amadeus Self-Service API (https://developers.amadeus.com) — when PROVIDER=amadeus
AMADEUS_API_KEY=your_key_here
AMADEUS_API_SECRET=your_secret_here
AMADEUS_ENV=test

# Scoring weights: best value = low cost + few stops/direct + short layovers
WEIGHT_PRICE=0.50
WEIGHT_STOPS=0.30
WEIGHT_LAYOVER=0.20

# Default search currency
CURRENCY=USD

# Uptime watchdog (scripts/watchdog.py, run by flights-watchdog.timer)
WATCHDOG_EMAIL=you@example.com
WATCHDOG_URL=http://localhost:8000/
